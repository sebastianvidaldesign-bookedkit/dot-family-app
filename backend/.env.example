APP_NAME=Dot
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-api.railway.app

LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dot
DB_USERNAME=dot
DB_PASSWORD=secret

BROADCAST_CONNECTION=log
CACHE_STORE=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=database

SANCTUM_STATEFUL_DOMAINS=your-frontend.railway.app,localhost:5173
FRONTEND_URL=https://your-frontend.railway.app

# Do NOT add any third-party analytics, tracking, or logging services.
